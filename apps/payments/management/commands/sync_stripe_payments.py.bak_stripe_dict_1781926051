from decimal import Decimal
from datetime import timedelta

from django.conf import settings
from django.core.management.base import BaseCommand
from django.utils import timezone


def gv(obj, key, default=None):
    if obj is None:
        return default
    if isinstance(obj, dict):
        return obj.get(key, default)
    return getattr(obj, key, default)


def cents(value):
    try:
        return Decimal(value or 0) / Decimal('100')
    except Exception:
        return Decimal('0')


class Command(BaseCommand):
    help = 'Sync Stripe checkout payments, create invoices, and send invoice emails.'

    def add_arguments(self, parser):
        parser.add_argument('--dry-run', action='store_true')
        parser.add_argument('--limit', type=int, default=50)
        parser.add_argument('--hours', type=int, default=72)

    def handle(self, *args, **opts):
        import stripe
        from apps.payments.models import Payment, Invoice
        from apps.payments.services import send_invoice_email

        stripe.api_key = settings.STRIPE_SECRET_KEY

        checked = 0
        imported = 0
        marked_paid = 0
        emailed = 0

        # Import recent Stripe sessions that were created before Payment tracking existed.
        since = int((timezone.now() - timedelta(hours=opts['hours'])).timestamp())
        try:
            sessions = stripe.checkout.Session.list(
                limit=min(opts['limit'], 100),
                created={'gte': since},
            )
            for session in sessions.auto_paging_iter():
                sid = gv(session, 'id', '')
                if not sid:
                    continue

                exists = Payment.objects.filter(stripe_checkout_session_id=sid).exists()
                if exists:
                    continue

                amount = cents(gv(session, 'amount_total', 0))
                currency = (gv(session, 'currency', None) or getattr(settings, 'STRIPE_CURRENCY', 'aed')).lower()
                metadata = gv(session, 'metadata', {}) or {}
                label = gv(metadata, 'label', '') or 'Stripe Checkout'

                if opts['dry_run']:
                    imported += 1
                    continue

                payment = Payment.objects.create(
                    source='stripe_checkout_import',
                    description=label,
                    amount=amount,
                    currency=currency,
                    status='pending',
                    stripe_checkout_session_id=sid,
                    raw_data=dict(session),
                )
                imported += 1
                self.stdout.write(f'Imported Stripe session into Payment #{payment.id}: {sid}')
        except Exception as e:
            self.stdout.write(self.style.WARNING(f'Import recent sessions skipped: {e}'))

        qs = Payment.objects.filter(
            stripe_checkout_session_id__gt='',
        ).exclude(status__in=['paid', 'refunded', 'disputed']).order_by('-id')[:opts['limit']]

        for payment in qs:
            checked += 1

            try:
                session = stripe.checkout.Session.retrieve(
                    payment.stripe_checkout_session_id,
                    expand=['payment_intent'],
                )
            except Exception as e:
                self.stdout.write(self.style.WARNING(f'Cannot retrieve session for Payment #{payment.id}: {e}'))
                continue

            status = gv(session, 'payment_status', '')
            self.stdout.write(f'Checking Payment #{payment.id}: {status}')

            if status != 'paid':
                continue

            if opts['dry_run']:
                marked_paid += 1
                continue

            customer = gv(session, 'customer_details', {}) or {}
            payment.customer_email = gv(customer, 'email', '') or payment.customer_email
            payment.customer_name = gv(customer, 'name', '') or payment.customer_name
            payment.status = 'paid'
            payment.paid_at = payment.paid_at or timezone.now()
            payment.raw_data = dict(session)

            pi = gv(session, 'payment_intent', None)
            pi_id = gv(pi, 'id', pi if isinstance(pi, str) else '')
            if pi_id:
                payment.stripe_payment_intent_id = pi_id

                try:
                    charges = stripe.Charge.list(
                        payment_intent=pi_id,
                        limit=1,
                        expand=['data.balance_transaction'],
                    )
                    data = gv(charges, 'data', []) or []
                    if data:
                        charge = data[0]
                        payment.stripe_charge_id = gv(charge, 'id', '') or ''
                        bt = gv(charge, 'balance_transaction', None)
                        payment.stripe_balance_transaction_id = gv(bt, 'id', bt if isinstance(bt, str) else '') or ''
                        if bt and not isinstance(bt, str):
                            payment.stripe_fee = cents(gv(bt, 'fee', 0))
                            payment.net_amount = cents(gv(bt, 'net', 0))
                except Exception as e:
                    self.stdout.write(self.style.WARNING(f'Fee read skipped for Payment #{payment.id}: {e}'))

            if not payment.net_amount:
                payment.net_amount = payment.amount - payment.stripe_fee

            payment.save()
            marked_paid += 1

            invoice, created = Invoice.objects.get_or_create(payment=payment)

            if payment.customer_email and not invoice.email_sent_at:
                try:
                    if send_invoice_email(invoice):
                        emailed += 1
                        self.stdout.write(self.style.SUCCESS(f'Invoice sent for Payment #{payment.id}: {payment.customer_email}'))
                    else:
                        self.stdout.write(self.style.WARNING(f'Invoice not sent for Payment #{payment.id}: no email provider success'))
                except Exception as e:
                    self.stdout.write(self.style.ERROR(f'Invoice email failed for Payment #{payment.id}: {e}'))

        self.stdout.write(self.style.SUCCESS(
            f'Checked {checked}, imported {imported}, marked paid {marked_paid}, invoice emails sent {emailed}'
        ))
