from decimal import Decimal
from django.core.management.base import BaseCommand
from django.utils import timezone


class Command(BaseCommand):
    help = 'Sync pending Stripe payments, create invoices, and send invoice emails.'

    def add_arguments(self, parser):
        parser.add_argument('--limit', type=int, default=50)
        parser.add_argument('--dry-run', action='store_true')

    def handle(self, *args, **opts):
        import stripe
        from django.conf import settings
        from apps.payments.models import Payment, Invoice
        from apps.payments.services import send_invoice_email

        stripe.api_key = settings.STRIPE_SECRET_KEY

        qs = Payment.objects.filter(
            status='pending',
            stripe_checkout_session_id__gt='',
        ).order_by('-created_at')[:opts['limit']]

        checked = 0
        paid = 0
        emailed = 0

        for payment in qs:
            checked += 1
            session = stripe.checkout.Session.retrieve(
                payment.stripe_checkout_session_id,
                expand=['payment_intent']
            )

            self.stdout.write(f'Checking payment #{payment.id}: {session.get("payment_status")}')

            if session.get('payment_status') != 'paid':
                continue

            if opts['dry_run']:
                paid += 1
                continue

            customer = session.get('customer_details') or {}
            payment.customer_email = customer.get('email') or payment.customer_email
            payment.customer_name = customer.get('name') or payment.customer_name
            payment.status = 'paid'
            payment.paid_at = timezone.now()
            payment.raw_data = dict(session)

            pi = session.get('payment_intent')
            if isinstance(pi, dict):
                payment.stripe_payment_intent_id = pi.get('id') or payment.stripe_payment_intent_id

                charges = pi.get('charges', {}).get('data', [])
                if charges:
                    charge = charges[0]
                    payment.stripe_charge_id = charge.get('id') or ''
                    bt_id = charge.get('balance_transaction') or ''
                    payment.stripe_balance_transaction_id = bt_id
                    if bt_id:
                        bt = stripe.BalanceTransaction.retrieve(bt_id)
                        payment.stripe_fee = Decimal(bt.get('fee') or 0) / Decimal('100')
                        payment.net_amount = Decimal(bt.get('net') or 0) / Decimal('100')

            if not payment.net_amount:
                payment.net_amount = payment.amount - payment.stripe_fee

            payment.save()
            paid += 1

            invoice, _ = Invoice.objects.get_or_create(payment=payment)
            if not invoice.email_sent_at and payment.customer_email:
                if send_invoice_email(invoice):
                    emailed += 1

        self.stdout.write(self.style.SUCCESS(
            f'Checked {checked}, marked paid {paid}, invoice emails sent {emailed}'
        ))
