@_platform_owner_required
def role_edit(request, tenant_pk, role_pk):
    tenant = get_object_or_404(Tenant, pk=tenant_pk)
    role = get_object_or_404(TenantRole, pk=role_pk, tenant=tenant)
    if request.method == "POST":
        form = TenantRoleForm(request.POST, tenant=tenant, instance=role)
        if form.is_valid():
            role = form.save()
            _log(request, tenant, "role_updated", role, {"name": role.name})
            messages.success(request, "تم تحديث الدور بنجاح.")
            return redirect("platform_core:tenant_detail", pk=tenant.pk)
    else:
        form = TenantRoleForm(tenant=tenant, instance=role)

    return render(request, "platform_core/role_form.html", {"tenant": tenant, "role": role, "form": form, "title": "تعديل دور"})


@_platform_owner_required
@require_POST
def role_delete(request, tenant_pk, role_pk):
    tenant = get_object_or_404(Tenant, pk=tenant_pk)
    role = get_object_or_404(TenantRole, pk=role_pk, tenant=tenant)
    name = role.name
    role.delete()
    _log(request, tenant, "role_deleted", None, {"name": name})
    messages.success(request, "تم حذف الدور.")
    return redirect("platform_core:tenant_detail", pk=tenant.pk)


@_platform_owner_required
def member_create(request, tenant_pk):
    tenant = get_object_or_404(Tenant, pk=tenant_pk)
    if request.method == "POST":
        form = TenantMembershipForm(request.POST, tenant=tenant)
        if form.is_valid():
            membership = form.save()
