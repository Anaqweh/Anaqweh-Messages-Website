            messages.success(request, "تم إضافة المستخدم للنسخة.")
            return redirect("platform_core:tenant_detail", pk=tenant.pk)
    else:
        form = TenantMembershipForm(tenant=tenant)

    return render(request, "platform_core/member_form.html", {"tenant": tenant, "form": form, "title": "إضافة مستخدم"})


@_platform_owner_required
def member_edit(request, tenant_pk, membership_pk):
    tenant = get_object_or_404(Tenant, pk=tenant_pk)
    membership = get_object_or_404(TenantMembership.objects.select_related("user"), pk=membership_pk, tenant=tenant)
    if request.method == "POST":
        form = TenantMembershipForm(request.POST, tenant=tenant, instance=membership)
        if form.is_valid():
            membership = form.save()
            _log(request, tenant, "member_updated", membership, {"user": str(membership.user)})
            messages.success(request, "تم تحديث صلاحيات المستخدم.")
            return redirect("platform_core:tenant_detail", pk=tenant.pk)
    else:
        form = TenantMembershipForm(tenant=tenant, instance=membership)

    return render(request, "platform_core/member_form.html", {"tenant": tenant, "membership": membership, "form": form, "title": "تعديل مستخدم"})


@_platform_owner_required
@require_POST
def member_delete(request, tenant_pk, membership_pk):
    tenant = get_object_or_404(Tenant, pk=tenant_pk)
    membership = get_object_or_404(TenantMembership.objects.select_related("user"), pk=membership_pk, tenant=tenant)
    username = str(membership.user)
    membership.delete()
    _log(request, tenant, "member_removed", None, {"user": username})
    messages.success(request, "تم إزالة المستخدم من النسخة.")
    return redirect("platform_core:tenant_detail", pk=tenant.pk)
