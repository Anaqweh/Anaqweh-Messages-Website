{% extends "base/base.html" %}
{% block title %}الحملات – INEXC{% endblock %}
{% block page_title %}<i class="bi bi-megaphone-fill me-2"></i>الحملات البريدية{% endblock %}
{% block top_actions %}<a href="{% url 'campaigns:campaign_create' %}" class="btn btn-inexc btn-sm">+ حملة جديدة</a>{% endblock %}
{% block content %}
<div class="data-table">
  <div class="p-3 border-bottom d-flex gap-2"><form method="get" class="d-flex gap-2 flex-grow-1"><input type="text" name="q" value="{{ search }}" class="form-control form-control-sm" placeholder="بحث..."><select name="status" class="form-select form-select-sm" style="width:auto"><option value="">كل الحالات</option>{% for v,l in status_choices %}<option value="{{ v }}" {% if v == status_filter %}selected{% endif %}>{{ l }}</option>{% endfor %}</select><button class="btn btn-sm btn-outline-primary">بحث</button></form></div>
  <table class="table table-hover"><thead><tr><th>الاسم</th><th>الحالة</th><th>المستلمون</th><th>مرسل</th><th>فاشل</th><th>النجاح</th><th>إجراءات</th></tr></thead><tbody>
    {% for c in campaigns %}
    <tr>
      <td><a href="{% url 'campaigns:campaign_detail' c.pk %}" class="fw-bold text-decoration-none text-dark">{{ c.name }}</a></td>
      <td><span class="badge bg-{{ c.get_status_color }}">{{ c.get_status_display }}</span></td>
      <td>{{ c.total_recipients }}</td><td class="text-success fw-bold">{{ c.sent_count }}</td><td class="text-danger">{{ c.failed_count }}</td>
      <td><small>{{ c.success_rate }}%</small></td>
      <td><div class="d-flex gap-1">
        <a href="{% url 'campaigns:campaign_detail' c.pk %}" class="btn btn-xs btn-outline-primary"><i class="bi bi-eye"></i></a>
        {% if c.status in 'draft,paused' %}<a href="{% url 'campaigns:campaign_action' c.pk 'start' %}" class="btn btn-xs btn-success"><i class="bi bi-play-fill"></i></a>{% endif %}
        {% if c.status == 'running' %}<a href="{% url 'campaigns:campaign_action' c.pk 'pause' %}" class="btn btn-xs btn-warning"><i class="bi bi-pause-fill"></i></a>{% endif %}
        {% if c.status not in 'completed,cancelled' %}<a href="{% url 'campaigns:campaign_action' c.pk 'cancel' %}" class="btn btn-xs btn-danger" onclick="return confirm('إلغاء؟')"><i class="bi bi-x-lg"></i></a>{% endif %}
      </div></td>
    </tr>
    {% empty %}<tr><td colspan="7" class="text-center text-muted py-5">لا توجد حملات</td></tr>{% endfor %}
  </tbody></table>
</div>
{% endblock %}
