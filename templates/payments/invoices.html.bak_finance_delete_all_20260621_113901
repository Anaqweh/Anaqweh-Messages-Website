{% extends "base/base.html" %}
{% block title %}الفواتير{% endblock %}
{% block page_title %}الفواتير{% endblock %}
{% block content %}
<div class="data-table p-3">
<table class="table table-hover align-middle">
<thead><tr><th>رقم الفاتورة</th><th>العميل</th><th>المبلغ</th><th>أرسلت</th><th>فتحت</th><th></th></tr></thead>
<tbody>{% for i in invoices %}<tr><td>{{ i.invoice_number }}</td><td>{{ i.payment.customer_email }}</td><td>{{ i.payment.amount }} {{ i.payment.currency|upper }}</td><td>{{ i.email_sent_at|default:"-" }}</td><td>{{ i.open_count }}</td><td><a href="{% url 'payments:invoice_detail' i.pk %}" class="btn btn-sm btn-outline-primary">عرض</a></td></tr>{% empty %}<tr><td colspan="6" class="text-center text-muted">لا توجد فواتير</td></tr>{% endfor %}</tbody>
</table>
</div>
{% endblock %}
