{% extends "base.html" %}
{% block title %}{{ tenant.name }}{% endblock %}
{% block content %}
<div class="container py-4" dir="rtl">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h2 class="mb-1">{{ tenant.name }}</h2>
      <div class="text-muted"><code>{{ tenant.slug }}</code> · {{ tenant.get_status_display }}</div>
    </div>
    <div>
      <a class="btn btn-outline-secondary" href="{% url 'platform_core:tenant_list' %}">النسخ</a>
      <a class="btn btn-primary" href="{% url 'platform_core:tenant_edit' tenant.pk %}">تعديل النسخة</a>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <div class="card p-3 h-100">
        <h5>بيانات المالك</h5>
        <p class="mb-1"><b>الاسم:</b> {{ tenant.owner_name|default:"-" }}</p>
        <p class="mb-1"><b>البريد:</b> {{ tenant.owner_email|default:"-" }}</p>
        <p class="mb-1"><b>الهاتف:</b> <span dir="ltr" style="unicode-bidi:isolate">{{ tenant.owner_phone|default:"-" }}</span></p>
        <p class="mb-0"><b>الدومين:</b> {{ tenant.domain|default:"-" }}</p>
      </div>
    </div>
    <div class="col-md-6">
      <div class="card p-3 h-100">
        <h5>الاشتراك</h5>
        <p class="mb-1"><b>الخطة:</b> {{ tenant.plan_name|default:"-" }}</p>
        <p class="mb-1"><b>البداية:</b> {{ tenant.subscription_starts_at|default:"-" }}</p>
        <p class="mb-0"><b>النهاية:</b> {{ tenant.subscription_ends_at|default:"-" }}</p>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <div class="card p-3 h-100">
        <h5>الوحدات</h5>
        {% for key,value in tenant.modules.items %}
          <div class="d-flex justify-content-between border-bottom py-1"><span>{{ key }}</span><b>{% if value %}مفعّل{% else %}مغلق{% endif %}</b></div>
        {% endfor %}
      </div>
    </div>
    <div class="col-md-6">
      <div class="card p-3 h-100">
        <h5>الحدود</h5>
        {% for key,value in tenant.limits.items %}
          <div class="d-flex justify-content-between border-bottom py-1"><span>{{ key }}</span><b>{{ value }}</b></div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
      <strong>الأدوار</strong>
      <a class="btn btn-sm btn-primary" href="{% url 'platform_core:role_create' tenant.pk %}">+ إضافة دور</a>
    </div>
    <div class="table-responsive">
      <table class="table mb-0">
        <thead><tr><th>الدور</th><th>نشط</th><th>نظامي</th><th></th></tr></thead>
        <tbody>
        {% for role in roles %}
          <tr>
            <td>{{ role.name }}</td>
            <td>{{ role.is_active|yesno:"نعم,لا" }}</td>
            <td>{{ role.is_system|yesno:"نعم,لا" }}</td>
            <td>
              <a class="btn btn-sm btn-outline-secondary" href="{% url 'platform_core:role_edit' tenant.pk role.pk %}">تعديل</a>
              <form method="post" action="{% url 'platform_core:role_delete' tenant.pk role.pk %}" style="display:inline" onsubmit="return confirm('حذف هذا الدور؟');">{% csrf_token %}<button class="btn btn-sm btn-outline-danger">حذف</button></form>
            </td>
          </tr>
        {% empty %}
          <tr><td colspan="4" class="text-center text-muted py-3">لا توجد أدوار بعد.</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="card mb-3">
    <div class="card-header d-flex justify-content-between align-items-center">
      <strong>المستخدمون داخل النسخة</strong>
      <a class="btn btn-sm btn-primary" href="{% url 'platform_core:member_create' tenant.pk %}">+ إضافة مستخدم</a>
    </div>
    <div class="table-responsive">
      <table class="table mb-0">
        <thead><tr><th>المستخدم</th><th>الدور</th><th>مدير نسخة</th><th>نشط</th><th></th></tr></thead>
        <tbody>
        {% for m in memberships %}
          <tr>
            <td>{{ m.user }}</td>
            <td>{{ m.role_name|default:m.role.name|default:"-" }}</td>
            <td>{{ m.is_tenant_admin|yesno:"نعم,لا" }}</td>
            <td>{{ m.is_active|yesno:"نعم,لا" }}</td>
            <td>
              <a class="btn btn-sm btn-outline-secondary" href="{% url 'platform_core:member_edit' tenant.pk m.pk %}">صلاحيات</a>
              <form method="post" action="{% url 'platform_core:member_delete' tenant.pk m.pk %}" style="display:inline" onsubmit="return confirm('إزالة هذا المستخدم من النسخة؟');">{% csrf_token %}<button class="btn btn-sm btn-outline-danger">إزالة</button></form>
            </td>
          </tr>
        {% empty %}
          <tr><td colspan="5" class="text-center text-muted py-3">لا يوجد مستخدمون مرتبطون بعد.</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>
{% endblock %}
